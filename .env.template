# WTF Studio Environment Variables Template
# Copy this to .env and fill in your values

# =============================================================================
# SECURITY (REQUIRED IN PRODUCTION)
# =============================================================================
WTF_SECRET_KEY=your-secret-key-here-change-in-production
WTF_PORTAL_KEY=your-portal-auth-key-here

# =============================================================================
# PERSISTENCE (RENDER DEPLOYMENT)
# =============================================================================
# For Render persistent disk mounted at /var/data:
# Set these to persist user accounts and files across deploys
#
# DB_PATH=/var/data/wtf_studio.db
# STORAGE_ROOT=/var/data/storage
#
# Defaults (local dev):
# DB_PATH=portal/private/db/wtf_studio.db
# STORAGE_ROOT=portal/private/storage

DB_PATH=
STORAGE_ROOT=

# =============================================================================
# FFMPEG (OPTIONAL)
# =============================================================================
# Custom FFmpeg paths (defaults to system PATH)
# FFMPEG_PATH=/path/to/ffmpeg
# FFPROBE_PATH=/path/to/ffprobe
